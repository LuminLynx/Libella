<?xml version="1.0" encoding="utf-8"?>
<!--
  Data extraction rules for Android 12+ (API 31+). Same exclusion as
  backup_rules.xml, applied to both cloud backup and direct device-to-device
  transfer. Keeps everything else in scope so users keep their non-sensitive
  state across device migrations.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="ai101_auth_prefs.xml" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="ai101_auth_prefs.xml" />
    </device-transfer>
</data-extraction-rules>
