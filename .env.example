# Local development environment template.
#
# Copy to .env at the repo root and fill in real values:
#     cp .env.example .env
#     chmod 600 .env          # restrict to your user only
#
# .env is gitignored and MUST NOT be committed. Production
# (Railway/CI) supplies these as real platform env vars; config.py
# loads .env with override=False, so platform env always wins and a
# missing .env is a harmless no-op.
#
# Source of truth for real values: Railway dashboard -> Variables.

# Anthropic API key used by the regression-set grader
# (backend/app/config.py -> AI_PROVIDER_API_KEY). ~108 chars,
# starts with sk-ant-. Paste on ONE line, no surrounding quotes,
# no trailing newline.
AI_PROVIDER_API_KEY=

# Postgres connection string for ingest + gate runs.
# postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=

# Optional overrides (defaults in backend/app/config.py are fine for
# local work; uncomment only to change them).
# AI_MODEL=claude-sonnet-4-6
# AI_PROVIDER_BASE_URL=https://api.anthropic.com/v1
# APP_ENV=development
