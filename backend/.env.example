# Preferred single URL configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai101

# Optional split configuration (used only when DATABASE_URL is unset)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ai101
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# App runtime settings
APP_HOST=0.0.0.0
APP_PORT=8000
